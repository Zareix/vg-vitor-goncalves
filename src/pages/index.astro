---
import { Font, Image } from "astro:assets";
import { getCollection } from "astro:content";

import heroImg from "../assets/hero.jpg";

import "../styles/global.css";

const VG = {
  email: "contact@vitor-goncalves.fr",
  phone: "+33 X XX XX XX XX",
  services: [
    {
      num: ".01",
      title: "Maçonnerie générale",
      desc: "Gros œuvre, murs, cuisine, ouvertures, dalles et fondations.",
    },
    {
      num: ".02",
      title: "Peinture & finitions",
      desc: "Intérieur, extérieur, enduits décoratifs et reprises soignées.",
    },
    {
      num: ".03",
      title: "Menuiserie",
      desc: "Sur-mesure bois, meubles, parquets et agencements.",
    },
  ],
  stats: [
    { k: "Interlocuteur", v: "Unique" },
    { k: "Devis", v: "Gratuit" },
    { k: "Zone", v: "Île-de-France" },
  ]
};

const realisations = (await getCollection("realisations"))
  .map((entry) => entry.data);

const tel = VG.phone.replace(/\s/g, "");
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>VG Vitor Gonçalves — Entreprise du bâtiment · Île-de-France</title>
    <Font cssVariable="--font-serif" />
    <Font cssVariable="--font-sans" />
    <Font cssVariable="--font-mono" />
  </head>
  <body class="bg-dossier text-ink font-sans m-0 p-0">
    <!-- TOP STRIP -->
    <div
      class="bg-ink text-cream flex justify-between px-6 py-2.5 text-[11px] tracking-[0.14em] uppercase lg:px-12"
    >
      <span class="hidden md:block">Île-de-France</span>
      <span>{VG.email}</span>
      <span>{VG.phone}</span>
    </div>

    <!-- HEADER -->
    <header
      class="flex flex-col items-start gap-5 px-6 py-8 border-b-[1.5px] border-ink lg:flex-row lg:items-center lg:justify-between lg:px-12"
    >
      <div class="flex items-center gap-4">
        <div
          class="w-14 h-14 bg-ink text-cream flex items-center justify-center font-serif font-bold text-2xl tracking-[-0.04em] shrink-0"
        >
          VG
        </div>
        <div>
          <div
            class="font-serif font-bold text-[22px] tracking-[-0.01em] leading-none"
          >
            Vitor Gonçalves
          </div>
          <div class="text-[11px] tracking-[0.14em] uppercase text-mute mt-1">
            Maçonnerie · Peinture · Menuiserie
          </div>
        </div>
      </div>
      <nav
        class="flex gap-3.5 text-[11px] tracking-[0.12em] uppercase sm:gap-6 sm:text-xs"
      >
        <a
          href="#services"
          class="no-underline hover:text-terre transition-colors duration-150"
          >Services</a
        >
        <a
          href="#realisations"
          class="no-underline hover:text-terre transition-colors duration-150"
          >Réalisations</a
        >
        <a
          href="#apropos"
          class="no-underline hover:text-terre transition-colors duration-150"
          >À propos</a
        >
        <a
          href="#contact"
          class="no-underline hover:text-terre transition-colors duration-150"
          >Contact</a
        >
      </nav>
    </header>

    <!-- HERO -->
    <section
      class="grid grid-cols-1 border-b-[1.5px] border-ink lg:grid-cols-[1.25fr_1fr] lg:min-h-150"
    >
      <div
        class="px-6 pt-12 pb-10 border-b-[1.5px] border-ink lg:px-12 lg:pt-20 lg:pb-16 lg:border-b-0 lg:border-r-[1.5px]"
      >
        <p class="text-[11px] tracking-[0.16em] uppercase text-mute m-0 mb-7">
          Entreprise générale du bâtiment
        </p>
        <h1
          class="font-serif font-bold text-[40px] leading-[0.98] tracking-tight mt-7 mb-8 sm:text-[52px] lg:text-[84px]"
        >
          Maçonnerie,<br />peinture<br />et menuiserie.
        </h1>
        <p class="text-[17px] leading-[1.65] mb-10 text-mute lg:max-w-130">
          VG Vitor Gonçalves est une entreprise familiale du bâtiment basée en
          Île-de-France. Nous intervenons chez les particuliers pour la
          construction, la rénovation et les travaux d'aménagement.
        </p>
        <div class="flex gap-3 flex-wrap">
          <a
            href={`tel:${tel}`}
            class="bg-ink text-cream no-underline px-5.5 py-4 text-[13px] tracking-[0.12em] uppercase hover:opacity-85 transition-opacity duration-150"
            >Nous appeler</a
          >
          <a
            href={`mailto:${VG.email}`}
            class="text-ink no-underline px-5.5 py-4 text-[13px] tracking-[0.12em] uppercase border-[1.5px] border-ink hover:bg-ink hover:text-cream transition-all duration-150"
            >Demander un devis</a
          >
        </div>
      </div>
      <div class="relative min-h-75">
        <Image
          src={heroImg}
          alt="Chantier VG Vitor Gonçalves"
          class="absolute inset-0 w-full h-full object-cover"
        />
      </div>
    </section>

    <!-- SERVICES -->
    <section
      class="px-6 py-14 border-b-[1.5px] border-ink lg:px-12 lg:py-20"
      id="services"
    >
      <div
        class="grid grid-cols-1 gap-3 mb-10 lg:grid-cols-[280px_1fr] lg:gap-12"
      >
        <div class="text-[11px] tracking-[0.16em] uppercase text-mute">
          01 / Services
        </div>
        <h2
          class="font-serif font-medium text-[40px] tracking-[-0.02em] m-0 leading-[1.1]"
        >
          Nos domaines d'intervention.
        </h2>
      </div>
      <div class="grid grid-cols-1 border-[1.5px] border-ink lg:grid-cols-3">
        {
          VG.services.map((s, i) => (
            <div
              class="p-7 not-last:border-b-[1.5px] border-ink lg:border-b-0! lg:border-r-[1.5px] lg:last:border-r-0",
            >
              <div class="mb-7">
                <span class="font-serif text-[44px] font-bold tracking-[-0.04em] leading-none">
                  {s.num}
                </span>
              </div>
              <div class="font-serif text-[26px] font-semibold tracking-[-0.01em] mb-3">
                {s.title}
              </div>
              <p class="text-sm leading-[1.6] text-mute mb-0">{s.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- À PROPOS -->
    <section
      class="px-6 py-14 border-b-[1.5px] border-ink grid grid-cols-1 gap-12 lg:px-12 lg:py-20 lg:grid-cols-[1fr_1.1fr]"
      id="apropos"
    >
      <div>
        <div class="ph ph-paper w-full aspect-3/4">
          <span class="opacity-85 text-center p-4"
            >Portrait atelier / équipe</span
          >
        </div>
      </div>
      <div>
        <div class="text-[11px] tracking-[0.16em] uppercase text-mute mb-4">
          02 / À propos
        </div>
        <h2
          class="font-serif font-medium text-[44px] tracking-[-0.02em] mb-7 leading-[1.05] mt-0"
        >
          Une entreprise familiale à taille humaine.
        </h2>
        <p class="text-base leading-[1.7] mb-4">
          Vitor Gonçalves accompagne les particuliers d'Île-de-France sur leurs
          projets de construction, rénovation et aménagement. Nous intervenons
          directement, avec notre propre équipe, de l'étude à la livraison du
          chantier.
        </p>
        <p class="text-base leading-[1.7] text-mute m-0">
          Notre engagement : un devis clair, un projet adapté à vos besoins et
          un résultat à la hauteur de vos exigences.
        </p>
        <div
          class="grid grid-cols-1 border-[1.5px] border-ink mt-10 sm:grid-cols-3"
        >
          {
            VG.stats.map((row) => (
              <div
                class="px-5 py-4 not-last:border-b-[1.5px] border-ink sm:border-b-0! sm:not-last:border-r-[1.5px]",
              >
                <div class="text-[10px] tracking-[0.16em] uppercase text-mute mb-1.5">
                  {row.k}
                </div>
                <div class="font-serif text-[22px] font-bold tracking-[-0.02em]">
                  {row.v}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- RÉALISATIONS -->
    <section
      class="px-6 py-14 border-b-[1.5px] border-ink lg:px-12 lg:py-20"
      id="realisations"
    >
      <div
        class="flex flex-col gap-4 mb-8 lg:flex-row lg:justify-between lg:items-end lg:gap-0"
      >
        <div class="text-[11px] tracking-[0.16em] uppercase text-mute mb-3.5">
          03 / Réalisations
        </div>
          <h2 class="font-serif font-medium text-[44px] tracking-[-0.02em] m-0">
          Réalisations récentes.
        </h2>
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          realisations.map((p) => (
            <figure class="m-0 border-[1.5px] border-ink bg-cream">
              <div class="carousel aspect-4/3">
                {p.images.map((image) => <Image class="slide" src={image} alt={p.label}  />)}
              </div>
              <figcaption class="px-4 py-3.5 flex justify-between border-t-[1.5px] border-ink">
                <div>
                  <div class="font-serif text-[15px]tracking-[-0.01em]">
                    <span class="font-semibold">{p.city}</span> | {p.label}
                  </div>
                  <div class="text-[10px] tracking-[0.14em] uppercase text-mute mt-0.5">
                    {p.category}
                  </div>
                </div>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </section>

    <!-- CONTACT -->
    <section
      class="bg-ink text-cream px-6 py-14 lg:px-12 lg:py-20"
      id="contact"
    >
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
        <div>
          <div
            class="text-[11px] tracking-[0.16em] uppercase text-cream/55 mb-4"
          >
            04 / Contact
          </div>
          <h2
            class="font-serif font-medium text-[52px] tracking-[-0.03em] mb-6 leading-[1.05] mt-0"
          >
            Parlons de votre projet.
          </h2>
          <p class="text-base leading-[1.65] text-cream/70 m-0 lg:max-w-110">
            Contactez-nous par téléphone ou par email pour organiser un
            rendez-vous sur place et établir un devis détaillé.
          </p>
        </div>
        <div class="border border-cream/30 flex flex-col">
          <a
            href={`tel:${tel}`}
            class="grid grid-cols-[100px_1fr_auto] items-center gap-4 px-6 py-5 text-cream no-underline border-b border-cream/30 hover:bg-cream/6 transition-colors duration-150 sm:grid-cols-[120px_1fr_auto] sm:gap-6 sm:px-7 sm:py-6"
          >
            <div class="text-[10px] tracking-[0.18em] uppercase text-cream/55">
              Appeler
            </div>
            <div class="font-serif text-xl tracking-[-0.01em] sm:text-[26px]">
              {VG.phone}
            </div>
            <div>→</div>
          </a>
          <a
            href={`mailto:${VG.email}`}
            class="grid grid-cols-[100px_1fr_auto] items-center gap-4 px-6 py-5 text-cream no-underline border-b border-cream/30 hover:bg-cream/6 transition-colors duration-150 sm:grid-cols-[120px_1fr_auto] sm:gap-6 sm:px-7 sm:py-6"
          >
            <div class="text-[10px] tracking-[0.18em] uppercase text-cream/55">
              Email
            </div>
            <div class="font-serif text-base tracking-[-0.01em] sm:text-[22px]">
              {VG.email}
            </div>
            <div>→</div>
          </a>
          <div
            class="grid grid-cols-[100px_1fr] items-center gap-4 px-6 py-5 sm:grid-cols-[120px_1fr] sm:gap-6 sm:px-7 sm:py-6"
          >
            <div class="text-[10px] tracking-[0.18em] uppercase text-cream/55">
              Zone
            </div>
            <div class="font-serif text-base tracking-[-0.01em] sm:text-[22px]">
              Toute l'Île-De-France
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer
      class="bg-ink text-cream/55 px-6 py-5 border-t border-cream/15 flex flex-col gap-2 text-[11px] tracking-[0.14em] uppercase sm:flex-row sm:justify-between sm:gap-0 lg:px-12"
    >
      <span>© VG Vitor Gonçalves</span>
      <span>Île-de-France</span>
      <span>{VG.email}</span>
    </footer>
  </body>
</html>
