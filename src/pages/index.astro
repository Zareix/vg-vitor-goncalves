---
import "~/styles/global.css";

import { Font } from "astro:assets";

import { CONFIG } from "~/data";
import Header from "~/components/layout/header.astro";
import Footer from "~/components/layout/footer.astro";
import Hero from "~/components/hero.astro";
import Services from "~/components/services.astro";
import Contact from "~/components/contact.astro";
import Realisations from "~/components/realisations.astro";
import About from "~/components/about.astro";
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>VG Vitor Gonçalves — Entreprise du bâtiment · Île-de-France</title>
    <Font cssVariable="--font-serif" />
    <Font cssVariable="--font-sans" />
    <Font cssVariable="--font-mono" />
  </head>
  <body class="bg-dossier text-ink font-sans m-0 p-0">
    <Header />

    <Hero />
    <Services />
    <About />
    <Realisations />
    <Contact />

    <Footer />
  </body>
</html>
